# ====================================================================
# UniversalDL — Environment Variables
# Copy this file to .env and fill in your values
# Never commit your .env file to version control
# ====================================================================

# --- Flask Core -------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-256-bit-random-secret-key-change-this-immediately

# development or production
FLASK_ENV=development

# Port for development server
PORT=5000

# --- Database ---------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/dbname
DATABASE_URL=postgresql://universaldl:password@localhost:5432/universaldl

# Docker Compose database password
DB_PASSWORD=changeme_in_production

# --- Redis ------------------------------------------------------------
# Redis connection string used for Celery broker, cache, and rate limiting
REDIS_URL=redis://localhost:6379/0

# --- Google OAuth -----------------------------------------------------
# Create OAuth client in Google Cloud Console
# Redirect URI example: http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Email (SMTP) -----------------------------------------------------
# Gmail: enable App Passwords
# SendGrid: use username "apikey" and API key as password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password-or-sendgrid-key
MAIL_DEFAULT_SENDER=noreply@universaldl.com

# --- Razorpay Payments ------------------------------------------------
# Get keys from Razorpay dashboard
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Razorpay webhook secret
# Webhook URL: https://yourdomain.com/upgrade/webhook
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# --- File Storage -----------------------------------------------------
# Directory where downloads are temporarily stored
TEMP_DOWNLOAD_DIR=/tmp/universaldl

# How long to keep files before auto deletion in seconds
MAX_FILE_AGE_SECONDS=3600

# --- Error Monitoring -------------------------------------------------
# Leave empty to disable Sentry
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# --- Proxy Pool (Optional) -------------------------------------------
# Used for platforms that block direct requests
PROXY_PROVIDER_URL=https://proxy-provider.example.com/api
PROXY_PROVIDER_KEY=your-proxy-api-key

# --- Alerting (Optional) ---------------------------------------------
# PagerDuty integration key for extractor failure alerts
PAGERDUTY_INTEGRATION_KEY=your-pagerduty-integration-key

# --- Application Domain ----------------------------------------------
# Used for generating absolute URLs in emails and sitemap
APP_DOMAIN=https://universaldl.com

